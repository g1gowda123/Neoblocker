{
  "name": "extension-app",
  "displayName": "Extension app",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "scripts": {
    "dev": "npm run copy-wasm && plasmo dev",
    "build": "npm run copy-wasm && plasmo build",
    "package": "plasmo package",
    "copy-wasm": "mkdir -p build/chrome-mv3-dev/wasm && cp node_modules/@xenova/transformers/dist/ort-wasm-simd.wasm build/chrome-mv3-dev/wasm/ && cp node_modules/@xenova/transformers/dist/ort-wasm.wasm build/chrome-mv3-dev/wasm/ && echo [copy-wasm] done."
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost; object-src 'self';"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "wasm/*.wasm",
          "wasm/*.mjs"
        ],
        "matches": [
          "https://www.youtube.com/*",
          "https://www.instagram.com/*"
        ]
      }
    ]
  },
  "alias": {
    "onnxruntime-node": "./mock.js",
    "node:stream": "./mock.js",
    "node:stream/web": "./mock.js",
    "sharp": "./mock.js"
  }
}
